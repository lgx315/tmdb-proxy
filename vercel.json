{
    "version": 2,
    "redirects": [
        {
            "source": "/",
            "destination": "https://github.com/imaliang/tmdb-proxy",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/t/p/:path*",
            "destination": "https://image.tmdb.org/t/p/:path*"
        },
        {
            "source": "/:path*",
            "destination": "/api/tmdb.js"
        }
    ],
    "headers": [
        {
            "source": "/t/p/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=604800"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=43200"
                }
            ]
        }
    ]
}
